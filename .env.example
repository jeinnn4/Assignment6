# =============================================
# ENVIRONMENT VARIABLES - DO NOT COMMIT THIS FILE
# Copy this to .env and fill in your values
# =============================================

# Application
NODE_ENV=development
PORT=5000

# MongoDB Connection
# Replace with your actual MongoDB Atlas URI or local MongoDB URI
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxx.mongodb.net/devopsdb?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
